# Gateway 通訊模式：mqtt = 原本 MQTT；socket = TCP client 連到 VM-B TCP Management；both = 兩者同時啟用
COMM_MODE=both

# === TCP socket 對等雙通道（COMM_MODE=socket 或 both 時使用） ===
# 拓撲：兩邊各 listen + 互相 dial
#   下行：gateway 自己 listen GATEWAY_LISTEN_PORT (real)；server 經 proxy 5566 dial 進來
#   上行：gateway dial proxy 5567，proxy 轉到 server 的 real 15567 listen
#
# Port 規劃（沿用 MQTT 1883/11883 精神）：
#   5566 / 5567   = proxy 對外、被 honeypot 截取（client 連這裡）
#   15566 / 15567 = 服務本身真實 listen（proxy 內部轉到這）
#   無 proxy 時請把下面 5567 / 15566 都改成 real 15567 / 15566 直連
SOCKET_HOST=52.91.57.125
# 上行：走 proxy 5567 ── 沒 proxy 直連請改 15567
UPSTREAM_PORT=5567
# 下行：真實 listen 15566；proxy 從外部 5566 轉進來
GATEWAY_LISTEN_HOST=0.0.0.0
GATEWAY_LISTEN_PORT=15566

# === MQTT（COMM_MODE=mqtt 或 both 時使用） ===
# Gateway → Mosquitto Broker 連線設定
# BROKER_HOST: 從「Gateway 這台機器」路由得到的那個 broker 位址。
#   - Gateway 與 broker 同在 AWS VPC：可用 broker 的 private IP。
#   - Gateway 在別朵雲 / 你家網路：須用 broker 的「公網 IP 或 DNS」，且 broker 的
#     Security Group 必須允許「Gateway 對外的出口 IP」連 BROKER_PORT（否則會 timed out）。
# BROKER_PORT: 與 Mosquitto（或前置 proxy）對外 listen 埠一致（常見 1883 或 11883）。
BROKER_HOST=52.91.57.125
BROKER_PORT=1883
# 定時 DRD_10 回報間隔（秒）；預設 30。除錯可改小例如 10
GATEWAY_REPORT_INTERVAL=300
