# MongoDB on VM-B
MONGO_DB=streetlight
# Real mongo host port = 17017
# Proxy 預留 27017（well-known，攻擊者預期看到這個）→ 之後 proxy 上線就 forward 到 17017
# 部署：firewall 對外開 27017（給 proxy）、17017 鎖只允許 localhost / proxy
MONGO_PORT=17017
MONGO_DATA_DIR=./data

# === Auth ===
# 注意：這組帳密會在 subscriber/web_api/socket_server 三個服務的 .env 裡都用到；
# 而 subscriber 的 .env 又被刻意設計成可從 /.env 路徑被攻擊者讀走（honeypot bait）。
# 部署在真實環境請改成隨機強密碼，並且把這個檔案加進 .gitignore。
MONGO_USER=streetlight_admin
MONGO_PASS=Hn8KQZ3vR6tY9xA2
